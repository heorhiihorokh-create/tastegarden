# Reservation email delivery (optional — the form validates & logs without these).
# Create a key at https://resend.com and verify your sending domain.
RESEND_API_KEY=
# Where reservation requests are delivered (the restaurant's inbox):
RESERVATION_EMAIL=info@tastegarden.be
# From address on a domain verified in Resend (defaults to Resend's sandbox sender):
RESERVATION_FROM="Taste Garden <reservaties@tastegarden.be>"
