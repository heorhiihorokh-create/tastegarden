# Copy to .env.local and fill in. In production, set these in the host
# (Vercel → Settings → Environment Variables). NEVER commit real values.

# --- Supabase (database + admin auth). Server-only: do NOT add NEXT_PUBLIC_. ---
# Project URL and publishable (anon) key — safe to keep server-side.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Reservation email delivery (Resend). The form validates & logs without these. ---
# Create a key at https://resend.com and verify tastegarden.be as a sending domain.
RESEND_API_KEY=
# Where reservation requests are delivered (the restaurant's inbox):
RESERVATION_EMAIL=info@tastegarden.be
# From address on a domain verified in Resend (defaults to Resend's sandbox sender):
RESERVATION_FROM="Taste Garden <reservaties@tastegarden.be>"
